# LLM/Gemma 호출 키 (필수)
GOOGLE_API_KEY=your-google-api-key

# 메뉴/설명 번역용 Cloud Translation 키 (선택)
# 비워두면 GOOGLE_API_KEY를 fallback으로 사용합니다.
GOOGLE_TRANSLATE_API_KEY=

# 번역 API 사용 여부/타임아웃 (선택)
GOOGLE_TRANSLATE_TIMEOUT_SEC=10

# Bounding box OCR용 Vision 키 (선택)
# 비워두면 GOOGLE_API_KEY를 fallback으로 사용합니다.
GOOGLE_VISION_API_KEY=

# 선택: bbox 디버그 저장 경로
BBOX_LOCAL_OUTPUT_DIR=debug/bbox

# OCR(Vision) 설정(선택)
OCR_VISION_TIMEOUT_SEC=25
